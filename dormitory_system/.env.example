# ============================================================
# 环境变量示例（本地开发用）
# 复制为 .env 后修改（django-dotenv 可自动加载）
# Railway 部署时在 Dashboard 中设置这些变量
# ============================================================

# Django 密钥（生产环境务必更换为长随机字符串）
DJANGO_SECRET_KEY=django-insecure-replace-with-a-real-secret-key

# 调试模式
DJANGO_DEBUG=True

# 允许的主机（逗号分隔）
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.railway.app

# CSRF 信任来源
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://*.railway.app

# 日志级别
DJANGO_LOG_LEVEL=INFO

# ---- MySQL 配置（未设置 MYSQL_URL 时逐字段生效） ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=dormitory_db
MYSQL_USER=root
MYSQL_PASSWORD=123456

# ---- 或者直接用连接 URL（优先级高于逐字段） ----
# MYSQL_URL=mysql://root:123456@127.0.0.1:3306/dormitory_db
